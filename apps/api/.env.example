NODE_ENV=development
PORT=4000
API_VERSION=v1
APP_VERSION=0.1.0

# ─── Database ────────────────────────────────────────────────────────────────
# In production (e.g. Railway/Render), append ?connection_limit=10 to manage connection pools
DATABASE_URL=postgresql://syncspace:syncspace_password@localhost:5432/syncspace_dev?connection_limit=10

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:redis_password@localhost:6379  # if password is set

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_random_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=change_me_to_another_random_secret_at_least_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Cloudinary (Phase 6) ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Phase 5) ─────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@syncspace.dev

# ─── AWS S3 (optional) ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
